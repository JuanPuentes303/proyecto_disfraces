# ============================================================
# Disfraces Rivera — .gitignore
# Spring Boot · Maven · Java 17 · MySQL
# ============================================================

# ------------------------------------------------------------
# Credenciales y configuración sensible
# ------------------------------------------------------------
application.properties
application-prod.properties
application-staging.properties
*.env
.env
.env.*
secrets.properties

# ------------------------------------------------------------
# Maven
# ------------------------------------------------------------
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
.mvn/wrapper/maven-wrapper.jar
mvnw.cmd

# ------------------------------------------------------------
# Java
# ------------------------------------------------------------
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# ------------------------------------------------------------
# Archivos subidos por usuarios
# ------------------------------------------------------------
uploads/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
*.log.*
logs/
spring.log

# ------------------------------------------------------------
# IDEs — IntelliJ IDEA
# ------------------------------------------------------------
.idea/
*.iws
*.iml
*.ipr
out/

# ------------------------------------------------------------
# IDEs — Eclipse / STS
# ------------------------------------------------------------
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/
.apt_generated_tests/

# ------------------------------------------------------------
# IDEs — NetBeans
# ------------------------------------------------------------
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# ------------------------------------------------------------
# IDEs — VS Code
# ------------------------------------------------------------
.vscode/
!.vscode/extensions.json

# ------------------------------------------------------------
# macOS
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ------------------------------------------------------------
# Windows
# ------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------
# Linux
# ------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ------------------------------------------------------------
# Archivos temporales y de sistema
# ------------------------------------------------------------
*.tmp
*.swp
*.swo
*.bak
*.orig

# SSL / TLS certificates and keystores
*.p12
*.jks
*.keystore
src/main/resources/keystore/